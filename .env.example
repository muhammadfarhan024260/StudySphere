# Backend Configuration Template
# Copy this to .env and fill with your actual values

# Database Connection String - PostgreSQL (e.g. Neon, Supabase)
connection_string=postgresql://your_user:your_password@your_host/your_db?sslmode=require

# Backend - Server Configuration
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5000

# SMTP Configuration for Email OTP Verification
# For Gmail: Use App Password (https://support.google.com/accounts/answer/185833)
SMTP:Host=smtp.gmail.com
SMTP:Port=587
SMTP:Username=your_email@gmail.com
SMTP:Password=your_app_password_16_chars
SMTP:SenderEmail=your_email@gmail.com

# JWT Configuration
# Use a strong, random string of at least 32 characters for the secret
JWT:Secret=your-super-secret-jwt-key-minimum-32-characters-long
JWT:Issuer=StudySphere
JWT:Audience=StudySphereUsers

